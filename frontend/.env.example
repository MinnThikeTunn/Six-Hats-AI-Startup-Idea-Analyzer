# Backend the Vite dev server proxies /analyze, /analyze/stream, /health to.
# Defaults to the standard backend address if unset.
VITE_BACKEND_URL=http://127.0.0.1:8000

# Base URL the app calls directly. Leave empty to use the same origin (the dev
# proxy). Set this for production if the API lives on a different origin, e.g.
# VITE_API_BASE=https://api.example.com
VITE_API_BASE=
