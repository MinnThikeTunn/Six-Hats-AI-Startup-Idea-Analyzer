# Copy to .env and fill in. Never commit the real .env.

# Google Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Web search for the White Hat (https://app.tavily.com)
TAVILY_API_KEY=

# Optional overrides (any LangChain model string)
# SIX_HATS_MODEL=google_genai:gemini-3.1-flash-lite
# SIX_HATS_FAST_MODEL=google_genai:gemini-3.1-flash-lite

# Requests/min cap shared across all hats.
# Raise this if you enable billing / have higher quota.
# SIX_HATS_RPM=10
